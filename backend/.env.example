DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-long-random-string"
SESSION_SECRET="change-this-session-secret-too"

# GitHub OAuth — create at github.com/settings/developers (free, no card)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI providers — add at least one (all free, no card required)
GROQ_API_KEY="your-groq-api-key"           # console.groq.com
CEREBRAS_API_KEY="your-cerebras-api-key"   # cloud.cerebras.ai
OPENROUTER_API_KEY="your-openrouter-key"   # openrouter.ai/keys
GEMINI_API_KEY="your-gemini-api-key"       # aistudio.google.com/apikey

FRONTEND_URL="http://localhost:3000"
PORT=5000
